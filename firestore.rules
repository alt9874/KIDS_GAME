// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: visits
// Document ID: {date} (YYYY-MM-DD)
// Fields:
//   - date: string (required, YYYY-MM-DD)
//   - count: number (required, positive)
//   - referrers: map (required, keys are referrer URLs, values are numbers)
//   - lastUpdated: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "jsj20210104@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Statistics ---
    match /stats/global {
      // Everyone can read the visit count
      allow get: if true;
      
      // Everyone can increment the visit count or create the initial document
      allow update: if incoming().diff(existing()).affectedKeys().hasOnly(['totalVisits']) 
                    && incoming().totalVisits is number;
      
      allow create: if incoming().keys().hasOnly(['totalVisits'])
                    && incoming().totalVisits is number;
      
      // Only admin can reset or delete stats
      allow delete: if isAdmin();
    }

    // --- Game Settings ---
    match /settings/game {
      // Everyone can read the game configuration to play
      allow get: if true;
      
      // Only admin can change the game settings
      allow write: if isAdmin();
    }
  }
}
