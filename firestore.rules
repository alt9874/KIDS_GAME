// ===============================================================
// App Model: Pill Safety Game (Admin Protected)
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [PILLAR 0] Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "jsj20210104@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- System Settings (Admin Only Write) ---
    match /settings/{settingsId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // --- Statistics (Global Counter) ---
    match /stats/{statsId} {
      allow get: if true;
      allow update: if true; // Increment total visits
      allow write: if isAdmin();
    }

    // --- Visit Logs (Security Hardened) ---
    match /visit_logs/{logId} {
      // Anyone can create a log, but NO ONE can read/list/delete except Admin
      allow create: if true; 
      allow read, list, delete: if isAdmin();
    }
  }
}
